# Copy to .env and fill (or decrypt media-stack.enc.env at deploy time).
# General
PUID=1000
PGID=1000
TZ=Etc/UTC

# VPN (gluetun) — torrent traffic is routed through this
VPN_SERVICE_PROVIDER=your-provider
OPENVPN_USER=changeme
OPENVPN_PASSWORD=changeme
SERVER_REGIONS=your-region

# Media paths (point at your array mount)
DL=/data/downloads
TV=/data/tv
MOVIES=/data/movies
MUSIC=/data/music

# App secrets
SLSK_USERNAME=changeme
SLSK_PASSWORD=changeme
SLSKD_WEB_USER=changeme
SLSKD_WEB_PASS=changeme
SLSKD_API_KEY=changeme-long-random
SOULBEET_SECRET=changeme-long-random
