# Copy to .env and fill real values (or decrypt immich.enc.env at deploy time).
# The real values live encrypted in immich.enc.env (SOPS).
DB_PASSWORD=changeme-generate-a-long-random-string
DB_USERNAME=postgres
DB_DATABASE_NAME=immich
DB_DATA_LOCATION=./postgres
UPLOAD_LOCATION=/data
TZ=Etc/UTC
IMMICH_VERSION=release
