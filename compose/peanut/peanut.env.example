# Example only — the real values live in peanut.enc.env (SOPS-encrypted).
# NUT_HOST/NUT_PORT point at the NUT master (the Pi) by LAN IP, deliberately not
# by hostname: LAN DNS is AdGuard on `server`, which powers down during an
# outage, exactly when this dashboard is worth reading.
NUT_HOST=10.0.0.x
NUT_PORT=3493
# Initial admin account for the PeaNUT web UI / its Basic-Auth REST API.
WEB_USERNAME=admin
WEB_PASSWORD=change-me
