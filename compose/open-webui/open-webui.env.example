# Copy to .env and fill (or decrypt open-webui.enc.env at deploy time).
# OPENAI_API_KEY here is MiniMax's key -- it's interpolated into the
# OPENAI_API_KEYS list in docker-compose.yml (position 0, matching MiniMax's
# base URL). The local llama-swap stack (STT/TTS/RAG/task model too) needs no
# real key -- dummy placeholders for those live directly in docker-compose.yml.
OPEN_WEBUI_PORT=3000
WEBUI_DOCKER_TAG=main
OPENAI_API_KEY=sk-your-minimax-key
WEBUI_SECRET_KEY=changeme-long-random-string
